# Postgres connection string (required by api-server and packages/db)
# For a local dev database run: docker compose up -d db
DATABASE_URL=postgresql://theaitoolbox:theaitoolbox@localhost:5432/theaitoolbox

# Clerk — backend (api-server)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# Clerk — frontend (ai-tools-directory)
VITE_CLERK_PUBLISHABLE_KEY=

# Comma-separated Clerk user IDs allowed to access /admin
ADMIN_USER_IDS=

# Optional — defaults shown
# PORT=8080            # api-server listen port
# PORT=5173            # vite dev server port (when running the frontend)
# BASE_PATH=/          # vite base path (set if hosting under a subpath)
